# Bpicius uses Vite + React (NOT Next.js). Use VITE_ prefix — not NEXT_PUBLIC_.
# Production credentials live in Vercel Dashboard env vars (not committed files).
# From Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional alias (Supabase publishable key format sb_publishable_...)
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

VITE_API_URL=http://localhost:3001
VITE_AUTH_MODE=hybrid
# Set true for live QA / staging; false before public launch
VITE_ENABLE_TEST_ACCOUNTS=false

# Cloudflare Turnstile (free) — CAPTCHA for login/signup/password reset
# 1) Create widget at https://dash.cloudflare.com → Turnstile (add bpicius.com + localhost)
# 2) Supabase Dashboard → Auth → Bot and Abuse Protection → Enable CAPTCHA → Turnstile + Secret Key
# 3) Set site key here and in Vercel env
VITE_TURNSTILE_SITE_KEY=

# Auth0 (auto-provisioned when Vercel Auth0 integration is connected to the project)
# Vite also reads AUTH0_DOMAIN / AUTH0_CLIENT_ID from Vercel at build time.
VITE_AUTH0_ENABLED=true
# Tenant from Management API URL https://dev-h4lv4mbm0rw7335o.us.auth0.com/api/v2/
VITE_AUTH0_DOMAIN=dev-h4lv4mbm0rw7335o.us.auth0.com
# SPA Client ID from Auth0 Dashboard → Applications → Bpicius (Single Page Application)
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
# SPA callback — default is origin only (https://your-app.vercel.app). Must match Auth0 Allowed Callback URLs.
# VITE_AUTH0_CALLBACK_PATH=/login
# VITE_AUTH0_USE_REFRESH_TOKENS=true
# Canonical production URL (used in emails, campaigns, Auth0 fallbacks)
VITE_APP_URL=https://www.bpicius.com

# Sentry — create project at https://sentry.io (React), copy Client DSN from Project Settings
# Windows CLI: npm install -g @sentry/cli  (not curl|bash)
# Auth: sentry-cli login --auth-token YOUR_TOKEN  (token from sentry.io/settings/account/api/auth-tokens/)
VITE_SENTRY_DSN=

# Stripe Pro subscriptions (publishable key only — secret stays in Supabase Edge secrets)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Upstash Redis (after Vercel Upstash integration — auto-provisions KV_REST_API_* on backend)